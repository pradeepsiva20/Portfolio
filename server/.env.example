# Copy this file to .env and fill in your own values.
# The server works fine with NONE of these set — messages just get
# saved to server/data/messages.json instead of emailed to you.

# Port the API runs on locally
PORT=4000

# Optional: enable emailing new contact-form messages to yourself via Gmail.
# 1. Turn on 2-Step Verification on your Google account.
# 2. Create an "App Password" at https://myaccount.google.com/apppasswords
# 3. Put your Gmail address and that app password below (not your normal password).
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=

# Optional: secret key to view submitted messages at /api/messages?key=...
ADMIN_KEY=change-this-to-something-secret
